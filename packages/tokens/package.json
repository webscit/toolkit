    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@adobe/leonardo-contrast-colors": "^1.0.0",
    "style-dictionary": "^5.4.0",
    "@tokens-studio/sd-transforms": "^2.0.3"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  }
}
